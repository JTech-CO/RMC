{
    "name": "real-time-markdown-converter",
    "version": "1.1.0",
    "description": "Real-time Markdown Converter with IDE-like interface",
    "main": "index.html",
    "scripts": {
        "check": "node scripts/check.js",
        "check:all": "npm run check && npm run check:e2e",
        "check:e2e": "node scripts/e2e-smoke.js",
        "dev": "live-server --port=8000 --open=/index.html",
        "start": "npm run dev",
        "serve": "http-server -p 8000 -c-1 -o /index.html",
        "preview": "http-server -p 8000 -c-1",
        "test": "npm run check"
    },
    "keywords": [
        "markdown",
        "converter",
        "editor",
        "real-time"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "http-server": "^14.1.1",
        "live-server": "^1.2.2"
    }
}
